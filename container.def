Bootstrap: docker
From: python:3.10-slim

%files
    pyproject.toml /opt/distal/pyproject.toml
    uv.lock /opt/distal/uv.lock
    README.md /opt/distal/README.md
    distal /opt/distal/distal
    lerobot_policy_advantage /opt/distal/lerobot_policy_advantage
    lerobot_policy_pistar06 /opt/distal/lerobot_policy_pistar06

%post
    # EGL vendor config for NVIDIA
    mkdir -p /usr/share/glvnd/egl_vendor.d
    cat > /usr/share/glvnd/egl_vendor.d/10_nvidia.json << 'NVJSON'
{
    "file_format_version": "1.0.0",
    "ICD": {
        "library_path": "libEGL_nvidia.so.0"
    }
}
NVJSON

    apt-get update && apt-get install -y --no-install-recommends \
        curl ffmpeg libavutil-dev libavcodec-dev libavformat-dev libswscale-dev \
        git linux-libc-dev build-essential cmake \
        libosmesa6-dev libglfw3 \
    && rm -rf /var/lib/apt/lists/*

    # Install python packages
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    cd /opt/distal && uv sync --frozen

    # Install mise
    curl https://mise.run | sh
    echo 'eval "$($HOME/.local/bin/mise activate bash)"' >> ~/.bashrc

    # Suppress robotsuite warning
    /opt/distal/.venv/bin/python -m robosuite.scripts.setup_macros

%environment
    export PATH="/root/.local/bin:$PATH"
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export MUJOCO_GL=egl
    export PYOPENGL_PLATFORM=egl
    export TOKENIZERS_PARALLELISM=false

    # Cache directories
    export CACHE_DIR=${CACHE_DIR:-/data/engs-robotics-ml/kebl6123/.cache}
    export UV_CACHE_DIR=$CACHE_DIR/uv
    export HF_HOME=$CACHE_DIR/huggingface
    export LIBERO_CONFIG_PATH=$CACHE_DIR/libero
    export WANDB_CACHE_DIR=$CACHE_DIR/wandb
    export TORCHINDUCTOR_CACHE_DIR=$CACHE_DIR/torchinductor

%runscript
    . /opt/distal/.venv/bin/activate
    mise trust
    exec "$@"
